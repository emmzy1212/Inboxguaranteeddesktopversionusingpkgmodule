{
  "name": "inbox-guaranteed",
  "version": "1.0.0",
  "description": "Inbox Guaranteed - Email and SMS sending application",
  "author": "Your Name",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron . --disable-gpu --disable-software-rasterizer --sandbox=false\"",
    "dev:services": "concurrently \"cd ../senderbackend && npm start\" \"npm run dev\"",
    "dev:app": "cross-env NODE_ENV=development electron . --disable-gpu --disable-software-rasterizer --sandbox=false",
    "dev:full": "concurrently \"npm run dev:services\" \"wait-on http://localhost:5000 http://localhost:5173 && npm run dev:app\"",
    "client": "vite",
    "server": "cd ../senderbackend && node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "electron": "npm run build && electron .",
    "electron-dev": "concurrently \"npm run build\" \"wait-on dist/index.html && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "electron-build-win": "npm run build && electron-builder --win",
    "electron-build-mac": "npm run build && electron-builder --mac",
    "electron-build-linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.525.0",
    "luxon": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.30.1",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "electron-packager": "^17.1.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.4.2",
    "vitest": "^1.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.senderapp.desktop",
    "productName": "SenderApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
