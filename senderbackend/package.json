{
  "name": "inboxguaranteed-backend",
  "version": "1.0.0",
  "description": "Backend for InboxGuaranteed",
  "main": "server.cjs",
  "bin": "server.cjs",
  "scripts": {
    "start": "node server.cjs",
    "dev": "nodemon server.cjs",
    "test": "vitest",
    "build":"pkg --config package.json server.cjs --public-packages \"*\" --public"
  },
  "pkg": {
    "assets": [
      ".env",
      "views/**/*",
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "no-bytecode": [
      "node_modules/strnum/**"
    ],
    "ignore": [
      "node_modules/puppeteer/**/.local-chromium/**",
      "node_modules/puppeteer/.*"
    ]
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "html-pdf-node": "^1.0.8",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "pkg": "^5.8.1",
    "puppeteer-core": "^21.11.0",
    "resend": "^6.3.0",
    "sanitize-html": "^2.17.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^8.12.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "vitest": "^1.0.0"
  }
}
