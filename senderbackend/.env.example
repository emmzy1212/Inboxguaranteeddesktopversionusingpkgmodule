# Example environment configuration for production deployment
# Copy this to .env and update paths for your system

# Puppeteer external Chromium executable path
# Windows example:
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Or for Chromium:
# PUPPETEER_EXECUTABLE_PATH=C:\tools\chromium\chrome.exe

# Linux example:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# macOS example:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional: Puppeteer launch options
# Uncomment to enable headless mode (default: true)
# PUPPETEER_HEADLESS=true

# Application port
PORT=3000

# Database configuration
MONGODB_URI=mongodb://localhost:27017/inboxguaranteed

# JWT secret
JWT_SECRET=your-secret-key-here

# Other service keys
STRIPE_KEY=sk_test_...
SENDGRID_API_KEY=SG....

# Feature flags
ENABLE_PDF_EXPORT=true
ENABLE_EMAIL_TEMPLATES=true
